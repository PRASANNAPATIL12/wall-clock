---

<footer style="
  border-top: 1px solid var(--border);
  padding: 2.5rem 1.25rem;
  margin-top: 4rem;
  color: var(--fg-muted);
  font-size: 0.82rem;
">
  <div style="max-width: 900px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 2rem; justify-content: space-between;">
    <div>
      <p style="font-weight: 600; color: var(--fg); margin-bottom: 0.5rem;">Focus Clock</p>
      <p style="max-width: 260px; line-height: 1.6;">A free focus timer and productivity tracker. No ads, no subscriptions.</p>
    </div>
    <div style="display: flex; gap: 3rem; flex-wrap: wrap;">
      <div>
        <p style="font-weight: 600; color: var(--fg); margin-bottom: 0.75rem;">Learn</p>
        <div style="display: flex; flex-direction: column; gap: 0.4rem;">
          <a href="/learn/deep-work" style="color: var(--fg-muted);">Deep Work</a>
          <a href="/learn/focus-techniques" style="color: var(--fg-muted);">Focus Techniques</a>
          <a href="/learn/focus-apps" style="color: var(--fg-muted);">Focus Apps</a>
          <a href="/learn/productivity-tracking" style="color: var(--fg-muted);">Productivity Tracking</a>
        </div>
      </div>
      <div>
        <p style="font-weight: 600; color: var(--fg); margin-bottom: 0.75rem;">Glossary</p>
        <div style="display: flex; flex-direction: column; gap: 0.4rem;">
          <a href="/glossary/pomodoro-technique" style="color: var(--fg-muted);">Pomodoro Technique</a>
          <a href="/glossary/deep-work" style="color: var(--fg-muted);">Deep Work</a>
          <a href="/glossary/flow-state" style="color: var(--fg-muted);">Flow State</a>
          <a href="/glossary" style="color: var(--fg-muted);">All Terms →</a>
        </div>
      </div>
      <div>
        <p style="font-weight: 600; color: var(--fg); margin-bottom: 0.75rem;">Focus Clock</p>
        <div style="display: flex; flex-direction: column; gap: 0.4rem;">
          <a href="https://focusclock.app" style="color: var(--fg-muted);">Home</a>
          <a href="https://focusclock.app/app" style="color: var(--fg-muted);">Start Timer</a>
          <a href="https://focusclock.app/privacy" style="color: var(--fg-muted);">Privacy</a>
          <a href="https://focusclock.app/terms" style="color: var(--fg-muted);">Terms</a>
        </div>
      </div>
    </div>
  </div>
  <div style="max-width: 900px; margin: 2rem auto 0; padding-top: 1.5rem; border-top: 1px solid var(--border);">
    <p>© {new Date().getFullYear()} Focus Clock. All rights reserved.</p>
  </div>
</footer>
