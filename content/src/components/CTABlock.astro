---
export interface Props {
  heading?: string;
  body?: string;
  style?: string;
}

const {
  heading = 'Ready to start your first deep work session?',
  body = 'Focus Clock is free, runs in your browser, and tracks every session with beautiful analytics. No signup required to try.',
  style,
} = Astro.props;
---

<div style={`
  background: var(--fg-faint);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 2rem 2.25rem;
  margin-top: 3rem;
  text-align: center;
  ${style ?? ''}
`}>
  <p style="font-size: 1.15rem; font-weight: 600; color: var(--fg); margin-bottom: 0.6rem;">{heading}</p>
  <p style="font-size: 0.92rem; color: var(--fg-muted); max-width: 480px; margin: 0 auto 1.5rem; line-height: 1.65;">{body}</p>
  <a
    href="https://focusclock.app/app"
    style="
      display: inline-block;
      background: var(--accent);
      color: white;
      padding: 0.65rem 1.75rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      letter-spacing: -0.01em;
    "
  >
    Start Focus Timer — Free
  </a>
</div>
