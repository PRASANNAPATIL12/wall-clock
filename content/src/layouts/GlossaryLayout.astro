---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABlock from '../components/CTABlock.astro';

export interface Props {
  term: string;
  definition: string;
  description: string;
  canonicalUrl?: string;
  schema?: object | object[];
  relatedTerms?: Array<{ slug: string; label: string }>;
  relatedArticles?: Array<{ slug: string; label: string }>;
}

const {
  term,
  definition,
  description,
  canonicalUrl,
  schema,
  relatedTerms = [],
  relatedArticles = [],
} = Astro.props;

const definitionSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: term,
  description: definition,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Focus Clock Productivity Glossary',
    url: 'https://blog.focusclock.app/glossary',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Focus Clock', item: 'https://focusclock.app' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://blog.focusclock.app' },
    { '@type': 'ListItem', position: 3, name: 'Glossary', item: 'https://blog.focusclock.app/glossary' },
    { '@type': 'ListItem', position: 4, name: term, item: canonicalUrl ?? Astro.url.href },
  ],
};

const schemas = [definitionSchema, breadcrumbSchema, ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
---

<BaseLayout
  title={`What is ${term}? — Focus Clock Glossary`}
  description={description}
  canonicalUrl={canonicalUrl}
  schema={schemas}
>
  <Header />

  <main style="max-width: var(--max-w); margin: 0 auto; padding: 2rem 1.25rem 4rem;">
    <nav style="font-size: 0.8rem; color: var(--fg-muted); margin-bottom: 2rem;">
      <a href="https://focusclock.app" style="color: var(--fg-muted);">Focus Clock</a>
      <span style="margin: 0 0.4rem;">›</span>
      <a href="https://blog.focusclock.app" style="color: var(--fg-muted);">Blog</a>
      <span style="margin: 0 0.4rem;">›</span>
      <a href="/glossary" style="color: var(--fg-muted);">Glossary</a>
      <span style="margin: 0 0.4rem;">›</span>
      <span>{term}</span>
    </nav>

    <p style="font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 0.5rem;">Definition</p>
    <h1 style="font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1.25rem;">{term}</h1>

    <!-- Definition box -->
    <div style="
      background: var(--fg-faint);
      border-left: 3px solid var(--accent);
      border-radius: 0 10px 10px 0;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    ">
      <p style="font-size: 1.05rem; line-height: 1.7; color: var(--fg); margin: 0;">
        <strong>{term}</strong> — {definition}
      </p>
    </div>

    <div class="prose">
      <slot />
    </div>

    {(relatedTerms.length > 0 || relatedArticles.length > 0) && (
      <div style="margin-top: 3rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        {relatedTerms.length > 0 && (
          <div>
            <p style="font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--fg-muted); margin-bottom: 0.75rem;">Related Terms</p>
            <div style="display: flex; flex-direction: column; gap: 0.35rem;">
              {relatedTerms.map(t => (
                <a href={`/glossary/${t.slug}`} style="font-size: 0.9rem; color: var(--accent);">{t.label}</a>
              ))}
            </div>
          </div>
        )}
        {relatedArticles.length > 0 && (
          <div>
            <p style="font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--fg-muted); margin-bottom: 0.75rem;">Related Articles</p>
            <div style="display: flex; flex-direction: column; gap: 0.35rem;">
              {relatedArticles.map(a => (
                <a href={a.slug} style="font-size: 0.9rem; color: var(--accent);">{a.label}</a>
              ))}
            </div>
          </div>
        )}
      </div>
    )}

    <CTABlock style="margin-top: 2.5rem;" />
  </main>

  <Footer />
</BaseLayout>
